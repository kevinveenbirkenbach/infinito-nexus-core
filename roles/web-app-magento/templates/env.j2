# Magento environment
# Base references:
# - https://hub.docker.com/r/bitnamicharts/magento

# Host & URLs
MAGENTO_URL="{{ MAGENTO_URL }}"
MAGENTO_BACKEND_FRONTNAME="admin"
MAGENTO_USE_SECURE={{ lookup('tls', application_id, 'enabled') | bool | ternary('1','0') }}
MAGENTO_BASE_URL_SECURE={{ lookup('tls', application_id, 'enabled') | bool | ternary('1','0') }}
MAGENTO_USE_SECURE_ADMIN={{ lookup('tls', application_id, 'enabled') | bool | ternary('1','0') }}

# Admin (seed from global administrator)
MAGENTO_ADMIN_USERNAME="{{ lookup('users', 'administrator').username }}"
MAGENTO_ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
MAGENTO_ADMIN_EMAIL="{{ lookup('users', 'administrator').email }}"
MAGENTO_ADMIN_FIRSTNAME="{{ lookup('users', 'administrator').firstname }}"
MAGENTO_ADMIN_LASTNAME="{{ lookup('users', 'administrator').lastname }}"

# Database (central DB preferred)
MYSQL_HOST="{{ lookup('database', application_id, 'host') }}"
MYSQL_PORT="{{ lookup('database', application_id, 'port') }}"
MYSQL_USER="{{ lookup('database', application_id, 'username') }}"
MYSQL_PASSWORD={{ lookup('database', application_id, 'password') | dotenv_quote }}
MYSQL_DATABASE="{{ lookup('database', application_id, 'name') }}"

# Search (Magento 2.4+)
OPENSEARCH_HOST="search"
OPENSEARCH_PORT_NUMBER="9200"
OPENSEARCH_INITIAL_ADMIN_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
# SMTP (post-install you’ll wire these in Magento admin or env.php)
SMTP_HOST="{{ email.host }}"
SMTP_PORT="{{ email.port }}"
SMTP_USER="{{ email.username }}"
SMTP_PASSWORD={{ email.password | dotenv_quote }}
SMTP_PROTOCOL={{ email.tls | ternary('tls','ssl') }}
{% endif %}

# Misc
PHP_MEMORY_LIMIT="768M"

APACHE_SERVERNAME={{ MAGENTO_DOMAIN }}