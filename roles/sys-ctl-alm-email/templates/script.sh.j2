#!/bin/bash
set -u
# Reverse systemd escaping for human-readable mail subject/body
friendly="$(systemd-escape --unescape "$1")"

# Resolve sendmail path across distros (/usr/sbin on EL, /usr/bin on others).
sendmail_bin="$(command -v sendmail 2>/dev/null || true)"
if [ -z "$sendmail_bin" ] && [ -x /usr/sbin/sendmail ]; then
  sendmail_bin="/usr/sbin/sendmail"
fi
if [ -z "$sendmail_bin" ] && [ -x /usr/bin/sendmail ]; then
  sendmail_bin="/usr/bin/sendmail"
fi
if [ -z "$sendmail_bin" ]; then
  echo "ERROR: sendmail binary not found" >&2
  exit 1
fi

# Try status with given arg; if empty, also try the escaped version
STATUS_OUT="$(systemctl status --full "$1" 2>/dev/null | head -n 30)"
if [ -z "$STATUS_OUT" ]; then
  esc="$(systemd-escape "$1")"
  STATUS_OUT="$(systemctl status --full "$esc" 2>/dev/null | head -n 30)"
fi

mail_tmp="$(mktemp)"
trap 'rm -f "$mail_tmp"' EXIT

{% set email = lookup('email') %}
cat > "$mail_tmp" <<ERRMAIL
To: {{ lookup('users', 'administrator').email }}
From: systemd <{{ email['from'] }}>
Subject: ${friendly}
Content-Transfer-Encoding: 8bit
Content-Type: text/plain; charset=UTF-8

A problem with the service ${friendly} occurred:

$STATUS_OUT

ERRMAIL

timeout "{{ email.timeout }}s" "$sendmail_bin" -t < "$mail_tmp"
rc=$?

if [ "$rc" -eq 124 ] || [ "$rc" -eq 137 ]; then
  echo "ERROR: sendmail timed out after {{ email.timeout }}s" >&2
  exit 1
fi

exit "$rc"
