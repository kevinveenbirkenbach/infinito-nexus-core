{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {{ OPENLDAP_SERVICE }}:
    # Build local custom image (no Bitnami)
    build:
      context: "."
      dockerfile: Dockerfile
      args:
        OPENLDAP_IMAGE: "{{ OPENLDAP_IMAGE }}"
        OPENLDAP_VERSION: "{{ OPENLDAP_VERSION }}"
    image: "{{ OPENLDAP_IMAGE_CUSTOM }}"
    container_name: "{{ OPENLDAP_CONTAINER }}"
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}

{% if OPENLDAP_NETWORK_EXPOSE_LOCAL | bool %}
    ports:
      - {{ DOCKER_BIND_HOST }}:{{ports.localhost.ldap['svc-db-openldap']}}:{{ OPENLDAP_DOCKER_PORT_OPEN }}
{% endif %}

    volumes:
      # Persist data + config
      - 'data:/var/lib/ldap'
      # Rendered LDIFs (read-only)
      - '{{ OPENLDAP_LDIF_PATH_HOST }}:{{ OPENLDAP_LDIF_PATH_DOCKER }}:ro'

{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

{{ lookup('applications') | compose_volumes(
    application_id,
    database_volume=lookup('database', application_id, 'volume'),
    extra_volumes={'config': {'name': OPENLDAP_VOLUME ~ '_config'}, 'data': {'name': OPENLDAP_VOLUME}}
) }}

{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
