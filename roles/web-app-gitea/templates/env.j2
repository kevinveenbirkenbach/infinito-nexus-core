# Configuration
# @see https://docs.gitea.com/next/administration/config-cheat-sheet#repository-repository

# General
DOMAIN={{ lookup('domain',application_id) }}
RUN_MODE="{{ 'dev' if (ENVIRONMENT | lower) == 'development' else 'prod' }}"
ROOT_URL="{{ lookup('tls', application_id, 'url.base') }}"
APP_NAME="{{ lookup('config', application_id, 'compose.services.gitea.title') }}"
USER_UID=1000
USER_GID=1000

# Logging configuration
GITEA__log__MODE=console
GITEA__log__LEVEL={% if MODE_DEBUG | bool %}Debug{% else %}Info{% endif %}

# Database
DB_TYPE=mysql
DB_HOST={{ lookup('database', application_id, 'host') }}:{{ lookup('database', application_id, 'port') }}
DB_NAME={{ lookup('database', application_id, 'name') }}
DB_USER={{ lookup('database', application_id, 'username') }}
DB_PASSWD={{ lookup('database', application_id, 'password') }}
GITEA__database__MAX_OPEN_CONNS=50
GITEA__database__MAX_IDLE_CONNS=25
GITEA__database__CONN_MAX_LIFETIME=1h

{% if GITEA_REDIS_ENABLED | bool %}
# ------------------------------------------------
# Redis Configuration for Gitea
# ------------------------------------------------
# @see https://docs.gitea.com/administration/config-cheat-sheet#cache-cache

GITEA__cache__ENABLED=true
GITEA__cache__ADAPTER=redis
# use a different Redis DB index than oauth2-proxy
GITEA__cache__HOST=redis://{{ GITEA_REDIS_ADDRESS }}/1

# Store sessions in Redis (instead of the internal DB)
GITEA__session__PROVIDER=redis
GITEA__session__PROVIDER_CONFIG=network=tcp,addr={{ GITEA_REDIS_ADDRESS }},db=2,pool_size=100,idle_timeout=180

# Use Redis for background task queues
GITEA__queue__TYPE=redis
GITEA__queue__CONN_STR=redis://{{ GITEA_REDIS_ADDRESS }}/3
{% endif %}


# SSH
SSH_PORT={{ports.public.ssh[application_id]}}
SSH_LISTEN_PORT=22
SSH_DOMAIN={{ lookup('domain',application_id) }}

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
# Mail Configuration
# @see https://docs.gitea.com/next/installation/install-with-docker#managing-deployments-with-environment-variables
# @todo test
GITEA__mailer__ENABLED=true
GITEA__mailer__FROM={{ email['from'] }}
GITEA__mailer__PROTOCOL=smtps
GITEA__mailer__SMTP_ADDR={{ email.host }}
GITEA__mailer__SMTP_PORT={{ email.port }}
GITEA__mailer__USER={{ email.username }}
GITEA__mailer__PASSWD={{ email.password }}
{% endif %}

# Allow push creation
# @see https://github.com/go-gitea/gitea/issues/17619
GITEA__REPOSITORY__ENABLE_PUSH_CREATE_USER={{ lookup('config', application_id, 'compose.services.gitea.configuration.repository.enable_push_create_user') | lower }}
GITEA__REPOSITORY__DEFAULT_PRIVATE={{ lookup('config', application_id, 'compose.services.gitea.configuration.repository.default_private') | lower }}
GITEA__REPOSITORY__DEFAULT_PUSH_CREATE_PRIVATE={{ lookup('config', application_id, 'compose.services.gitea.configuration.repository.default_push_create_private') | lower }}

GITEA__security__INSTALL_LOCK=true # Locks the installation page

# (De)activate OIDC
GITEA__openid__ENABLE_OPENID_SIGNUP={{ GITEA_OIDC_ENABLED | lower }}
GITEA__openid__ENABLE_OPENID_SIGNIN={{ GITEA_OIDC_ENABLED | lower }}

{% if GITEA_IAM_ENABLED | bool %}

EXTERNAL_USER_DISABLE_FEATURES=deletion,manage_credentials,change_username,change_full_name

{% if ( GITEA_LDAP_ENABLED | bool ) %}
GITEA__ldap__SYNC_USER_ON_LOGIN=true
{% endif %}

{% endif %}

GITEA__service__DISABLE_REGISTRATION={{ GITEA_IAM_ENABLED | lower }}

{% if lookup('config', application_id, 'compose.services.prometheus.native_metrics.enabled', False) | bool %}
# Prometheus native metrics — scraped via internal port to bypass nginx/OAuth2.
GITEA__metrics__ENABLED=true
{% set _metrics_token = lookup('config', application_id, 'credentials.native_metrics_token', '') %}
{% if _metrics_token %}
GITEA__metrics__TOKEN={{ _metrics_token }}
{% endif %}
{% endif %}
