# Mattermost configuration
# @see https://docs.mattermost.com/configure/configuration-settings.html
# @see https://docs.mattermost.com/install/install-docker.html

MM_SERVICESETTINGS_SITEURL={{ lookup('tls', application_id, 'url.base') }}
MM_SERVICESETTINGS_LISTENADDRESS=:{{ container_port }}
MM_SERVICESETTINGS_ALLOWCORSFROM={{ lookup('tls', application_id, 'url.base') }}
MM_SERVICESETTINGS_ENABLELOCALMODE=true
MM_EXPERIMENTALSETTINGS_DISABLELANDINGPAGE=true

# Logging
MM_LOGSETTINGS_CONSOLELEVEL={% if MODE_DEBUG | bool %}DEBUG{% else %}INFO{% endif %}

MM_LOGSETTINGS_ENABLEFILE=false

# Database (PostgreSQL)
MM_SQLSETTINGS_DRIVERNAME=postgres
MM_SQLSETTINGS_DATASOURCE=postgres://{{ lookup('database', application_id, 'username') }}:{{ lookup('database', application_id, 'password') }}@{{ lookup('database', application_id, 'host') }}:{{ lookup('database', application_id, 'port') }}/{{ lookup('database', application_id, 'name') }}?sslmode=disable&connect_timeout=10
MM_SQLSETTINGS_MAXOPENCONNS=20
MM_SQLSETTINGS_MAXIDLECONNS=10

# File storage
MM_FILESETTINGS_DRIVERNAME=local
MM_FILESETTINGS_DIRECTORY=/mattermost/data/

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
# Mail Configuration
# @see https://docs.mattermost.com/configure/smtp-email.html
MM_EMAILSETTINGS_ENABLESMTPAUTH=true
MM_EMAILSETTINGS_SMTPSERVER={{ email.host }}
MM_EMAILSETTINGS_SMTPPORT={{ email.port }}
MM_EMAILSETTINGS_SMTPUSERNAME={{ email.username }}
MM_EMAILSETTINGS_SMTPPASSWORD={{ email.password | dotenv_quote }}
MM_EMAILSETTINGS_CONNECTIONSECURITY=TLS
MM_EMAILSETTINGS_FEEDBACKEMAIL={{ email['from'] }}
MM_EMAILSETTINGS_REPLYTOADDRESS={{ email['from'] }}
MM_EMAILSETTINGS_SENDEMAILNOTIFICATIONS=true
{% endif %}

{% if MATTERMOST_OIDC_ENABLED | bool %}
# SSO via GitLab OAuth2 / Keycloak
# @see https://docs.mattermost.com/deployment/sso-gitlab.html
MM_GITLABSETTINGS_ENABLE=true
MM_GITLABSETTINGS_ID={{ OIDC.CLIENT.ID }}
MM_GITLABSETTINGS_SECRET={{ OIDC.CLIENT.SECRET }}
MM_GITLABSETTINGS_AUTHENDPOINT={{ OIDC.CLIENT.AUTHORIZE_URL }}
MM_GITLABSETTINGS_TOKENENDPOINT={{ OIDC.CLIENT.TOKEN_URL }}
MM_GITLABSETTINGS_USERAPIENDPOINT={{ OIDC.CLIENT.USER_INFO_URL }}
{% endif %}

{% if lookup('config', application_id, 'compose.services.prometheus.native_metrics.enabled', False) | bool %}
# Prometheus native metrics — scraped via internal port to bypass nginx/OAuth2.
MM_METRICSSETTINGS_ENABLE=true
MM_METRICSSETTINGS_LISTENADDRESS=:{{ lookup('config', application_id, 'compose.services.prometheus.native_metrics.port') }}
{% endif %}
