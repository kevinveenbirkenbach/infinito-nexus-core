# Prometheus scrape configuration — auto-generated by Ansible
# DO NOT edit manually; update roles/web-app-prometheus/templates/configuration/prometheus.yml.j2

global:
  scrape_interval:     30s
  evaluation_interval: 30s
  external_labels:
    environment: "{{ DOMAIN_PRIMARY }}"

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["{{ ALERTMANAGER_CONTAINER }}:9093"]

rule_files:
  - "{{ ALERT_RULES_CONFIG_DOCKER }}"

scrape_configs:

  # Prometheus self-monitoring
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  # Central nginx metrics — scraped ONCE from the prometheus domain.
  # All app metrics are labeled by host/vhost via lua-resty-prometheus.
  # No per-app redundancy: one scrape gives metrics for all 70+ apps.
  - job_name: "nginx-metricz"
    scheme: {{ lookup('tls', application_id, 'protocols.web') }}
    metrics_path: /metricz
    tls_config:
      insecure_skip_verify: {{ not (TLS_ENABLED | bool) }}
    static_configs:
      - targets: ["{{ lookup('domain', application_id) }}"]

  # Container metrics — per-container CPU, memory, network via cAdvisor.
  - job_name: "cadvisor"
    static_configs:
      - targets: ["{{ CADVISOR_CONTAINER }}:8080"]

  # Host metrics — system-level CPU, memory, disk, network via node_exporter.
  # node-exporter runs with network_mode: host, so it binds on the real host.
  # host.docker.internal resolves to the host gateway from inside the container.
  - job_name: "node-exporter"
    static_configs:
      - targets: ["host.docker.internal:9100"]

  # ── Native application metrics ────────────────────────────────────────────
  # Auto-discovered via the native_metrics_apps lookup plugin.
  # A scrape job is included for each deployed app that has BOTH:
  #   - native_metrics.enabled: true  (set in inventory per-app)
  #   - roles/<native_prometheus_application_id>/templates/prometheus.yml.j2  (owned by the app role)
  # To add a new app: set native_metrics.enabled: true in its config and create
  # a prometheus.yml.j2 fragment in its templates/ directory.

{% for native_prometheus_application_id in lookup('native_metrics_apps') %}
{% include 'roles/' + native_prometheus_application_id + '/templates/prometheus.yml.j2' %}

{% endfor %}

  # Blackbox readiness probes — one target per canonical domain per application.
  # Proxied to the app backend: returns 502/503 when the app is down.
{% set canonical_map = lookup('applications') | canonical_domains_map(DOMAIN_PRIMARY) %}
  - job_name: "blackbox-healthz"
    metrics_path: /probe
    params:
      module: [http_ready]
    static_configs:
{% for _application_id in CURRENT_PLAY_APPLICATIONS | list | sort %}
{% if _application_id != application_id %}
{% set domains_raw = canonical_map.get(_application_id, []) %}
{% set canonical_probe_domains = (domains_raw.values() | list) if (domains_raw is mapping) else domains_raw %}
{% if canonical_probe_domains | length > 0 %}
      - targets:
{% for domain in canonical_probe_domains %}
          - "{{ lookup('tls', application_id, 'protocols.web') }}://{{ domain }}/healthz/ready"
{% endfor %}
        labels:
          app: "{{ _application_id }}"
{% endif %}
{% endif %}
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "{{ BLACKBOX_CONTAINER }}:9115"
