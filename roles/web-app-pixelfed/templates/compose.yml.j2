{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  application:
    image: "{{ PIXELFED_IMAGE }}:{{ PIXELFED_VERSION }}"
    container_name: {{ PIXELFED_CONTAINER }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    # Keep the application on the repo-managed entrypoint so the container is
    # ready for the Ansible bootstrap before Pixelfed's own first-start logic.
    entrypoint: "{{ PIXELFED_ENTRYPOINT_DOCKER }}"
    volumes:
      - "data:/var/www/storage"
      - "{{ PIXELFED_ENV_FILE }}:/var/www/.env"
      - "{{ PIXELFED_ENTRYPOINT_HOST_ABS }}:{{ PIXELFED_ENTRYPOINT_DOCKER }}:ro"
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ ports.localhost.http[application_id] }}:80"
{% include 'roles/sys-svc-container/templates/depends_on/dmbs_excl.yml.j2' %}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
  worker:
    container_name: {{ PIXELFED_WORKER_CONTAINER }}
    image: "{{ PIXELFED_IMAGE }}:{{ PIXELFED_VERSION }}"
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    environment:
      AUTORUN_LARAVEL_EVENT_CACHE: "false"
      AUTORUN_LARAVEL_ROUTE_CACHE: "false"
      AUTORUN_LARAVEL_VIEW_CACHE: "false"
      AUTORUN_ENABLED: "false"
    volumes:
      - "data:/var/www/storage"
      - "{{ PIXELFED_ENV_FILE }}:/var/www/.env"
    entrypoint: /worker-entrypoint.sh
    healthcheck:
      test: php artisan horizon:status | grep running
      interval: 60s
      timeout: 5s
      retries: 1
{% include 'roles/sys-svc-container/templates/depends_on/dmbs_incl.yml.j2' %}
      application:
        condition: service_started
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

{{ lookup('applications') | compose_volumes(
    application_id,
    database_volume=lookup('database', application_id, 'volume'),
    extra_volumes={'data': {'name': PIXELFED_VOLUME}}
) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
